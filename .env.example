# HeartStream V2 — copy to .env and fill in values

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── TMDB ─────────────────────────────────────────────────────────────────────
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=REPLACE_WITH_TMDB_API_KEY

# TMDB Read Access Token (v4) — used by Jackettio for metadata
# Same TMDB settings page → "API Read Access Token (v4)"
TMDB_ACCESS_TOKEN=REPLACE_WITH_TMDB_ACCESS_TOKEN

# ── Real-Debrid ───────────────────────────────────────────────────────────────
# Get your API key at https://real-debrid.com/apitoken
# Plans: ~$3.46/month (RD N°3 = 90 days for 9 EUR is best value)
REALDEBRID_API_KEY=REPLACE_WITH_REALDEBRID_API_KEY

# ── Jackett ───────────────────────────────────────────────────────────────────
# After first deploy, visit http://your-server:9117
# Copy the API key shown on the Jackett dashboard
JACKETT_API_KEY=REPLACE_WITH_JACKETT_API_KEY

# ── Jackettio tuning (optional — defaults shown) ──────────────────────────────
# Comma-separated Jackett indexer IDs to query
JACKETTIO_INDEXERS=thepiratebay,yts,eztv,therarbg

# Comma-separated quality values (pixels) to include
JACKETTIO_QUALITIES=720,1080,2160
